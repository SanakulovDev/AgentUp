{
    "name": "agentup-cli",
    "version": "0.1.19",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SanakulovDev/AgentUp.git"
    },
    "bugs": {
        "url": "https://github.com/SanakulovDev/AgentUp/issues"
    },
    "homepage": "https://github.com/SanakulovDev/AgentUp#readme",
    "publishConfig": {
        "provenance": true
    },
    "description": "CLI to generate AGENTS.md and AI coding agent scaffolding for Claude Code, Cursor, Codex, and Gemini",
    "type": "module",
    "bin": {
        "agentup-cli": "dist/index.js"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/index.ts",
        "selftest": "tsx src/index.ts __selftest",
        "version:show": "node -p \"require('./package.json').version\"",
        "release:patch": "npm version patch --no-git-tag-version",
        "release:minor": "npm version minor --no-git-tag-version",
        "release:major": "npm version major --no-git-tag-version",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@clack/prompts": "^0.8.2",
        "picocolors": "^1.1.1"
    },
    "devDependencies": {
        "@types/node": "^22.13.10",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    },
    "keywords": [
        "agentup",
        "agentup-cli",
        "agents-md",
        "ai",
        "ai-agent",
        "ai-coding-agent",
        "cli",
        "scaffolding",
        "developer-tools",
        "developer-experience",
        "context-engineering",
        "prompt-engineering",
        "claude-code",
        "cursor",
        "codex",
        "gemini"
    ],
    "license": "MIT"
}
